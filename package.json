{
  "name": "jawere-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces",
    "build": "npm run build --workspaces",
    "check": "npx tsc --noEmit",
    "setup": "tsx packages/coding-agent/src/cli.ts --setup",
    "start": "node --env-file .env.local --import tsx packages/coding-agent/src/cli.ts",
    "start:prod": "tsx packages/coding-agent/src/cli.ts",
    "test": "npm run test --workspaces --if-present",
    "publish:patch": "npm version patch -ws --no-git-tag-version",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
