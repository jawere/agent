{
  "$schema": "https://raw.githubusercontent.com/jawere/agent/main/models-schema.json",
  "version": "1.0",
  "defaultModel": "deepseek-v4-pro",
  "defaultProvider": "deepseek",

  "providers": {
    "deepseek": {
      "baseURL": "https://api.deepseek.com/v1",
      "envKey": "DEEPSEEK_API_KEY",
      "models": [
        { "id": "deepseek-v4-pro", "name": "DeepSeek V4 Pro", "contextWindow": 128000 },
        { "id": "deepseek-chat", "name": "DeepSeek Chat", "contextWindow": 64000 }
      ]
    },
    "openai": {
      "baseURL": "https://api.openai.com/v1",
      "envKey": "OPENAI_API_KEY",
      "models": [
        { "id": "gpt-4o", "name": "GPT-4o", "contextWindow": 128000 },
        { "id": "gpt-4o-mini", "name": "GPT-4o Mini", "contextWindow": 128000 },
        { "id": "gpt-4-turbo", "name": "GPT-4 Turbo", "contextWindow": 128000 },
        { "id": "o4-mini", "name": "o4-mini", "contextWindow": 200000 }
      ]
    },
    "anthropic": {
      "baseURL": "https://api.anthropic.com/v1",
      "envKey": "ANTHROPIC_API_KEY",
      "models": [
        { "id": "claude-sonnet-4-20250514", "name": "Claude Sonnet 4", "contextWindow": 200000 },
        { "id": "claude-opus-4-20250514", "name": "Claude Opus 4", "contextWindow": 200000 },
        { "id": "claude-3-5-sonnet-20241022", "name": "Claude 3.5 Sonnet", "contextWindow": 200000 }
      ]
    },
    "google": {
      "baseURL": "https://generativelanguage.googleapis.com/v1beta",
      "envKey": "GEMINI_API_KEY",
      "models": [
        { "id": "gemini-2.5-pro", "name": "Gemini 2.5 Pro", "contextWindow": 1048576 },
        { "id": "gemini-2.5-flash", "name": "Gemini 2.5 Flash", "contextWindow": 1048576 },
        { "id": "gemini-2.0-flash", "name": "Gemini 2.0 Flash", "contextWindow": 1048576 }
      ]
    },
    "groq": {
      "baseURL": "https://api.groq.com/openai/v1",
      "envKey": "GROQ_API_KEY",
      "models": [
        { "id": "llama-3.3-70b-versatile", "name": "Llama 3.3 70B", "contextWindow": 128000 },
        { "id": "deepseek-r1-distill-llama-70b", "name": "DeepSeek R1 Distill 70B", "contextWindow": 128000 }
      ]
    },
    "xai": {
      "baseURL": "https://api.x.ai/v1",
      "envKey": "XAI_API_KEY",
      "models": [
        { "id": "grok-3-beta", "name": "Grok 3 Beta", "contextWindow": 131072 }
      ]
    },
    "mistral": {
      "baseURL": "https://api.mistral.ai/v1",
      "envKey": "MISTRAL_API_KEY",
      "models": [
        { "id": "mistral-large-latest", "name": "Mistral Large", "contextWindow": 128000 },
        { "id": "codestral-latest", "name": "Codestral", "contextWindow": 256000 }
      ]
    },
    "openrouter": {
      "baseURL": "https://openrouter.ai/api/v1",
      "envKey": "OPENROUTER_API_KEY",
      "models": [
        { "id": "openai/gpt-4o", "name": "GPT-4o (OpenRouter)", "contextWindow": 128000 },
        { "id": "anthropic/claude-sonnet-4-20250514", "name": "Claude Sonnet 4 (OpenRouter)", "contextWindow": 200000 },
        { "id": "google/gemini-2.5-pro", "name": "Gemini 2.5 Pro (OpenRouter)", "contextWindow": 1048576 },
        { "id": "deepseek/deepseek-chat", "name": "DeepSeek Chat (OpenRouter)", "contextWindow": 64000 }
      ]
    },
    "custom": {
      "baseURL": "https://api.openai.com/v1",
      "envKey": "AI_API_KEY",
      "models": [
        { "id": "gpt-4o", "name": "GPT-4o (Custom)", "contextWindow": 128000 }
      ]
    }
  },

  "thinkingLevels": {
    "off": { "description": "No thinking — direct responses" },
    "minimal": { "description": "Brief reasoning before responding" },
    "low": { "description": "Some reasoning steps" },
    "medium": { "description": "Balanced reasoning" },
    "high": { "description": "Thorough reasoning for complex tasks" },
    "xhigh": { "description": "Maximum reasoning — use for critical/safety tasks" }
  },

  "defaults": {
    "thinkingLevel": "off",
    "timeout": 120
  }
}
